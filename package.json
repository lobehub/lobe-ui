    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-github": "^12.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remend": "^1.3.0",
    "shiki": "^4.3.1",
    "swr": "^2.4.2",
    "ts-md5": "^2.0.1",
    "unified": "^11.0.5",
