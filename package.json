    "@floating-ui/react": "^0.27.19",
    "@giscus/react": "^3.1.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@pierre/diffs": "1.2.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@shikijs/core": "^4.3.1",
    "@shikijs/stream": "^4.3.1",
    "@shikijs/transformers": "^4.3.1",
    "@splinetool/runtime": "1.12.98",
    "ahooks": "^3.9.7",
    "antd-style": "^4.1.0",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "emoji-mart": "^5.6.0",
    "es-toolkit": "^1.49.0",
    "fast-deep-equal": "^3.1.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "html-url-attributes": "^3.0.1",
    "immer": "^11.1.11",
    "katex": "^0.16.45",
    "leva": "^0.10.1",
    "lucide-react": "^1.24.0",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "motion": "^12.0.0",
    "numeral": "^2.0.6",
    "polished": "^4.3.1",
    "query-string": "^9.4.1",
    "rc-collapse": "^4.0.0",
    "rc-footer": "^0.6.8",
    "rc-image": "^7.12.0",
    "rc-input-number": "^9.5.0",
    "rc-menu": "^9.16.1",
    "re-resizable": "^6.11.2",
    "react-avatar-editor": "^15.1.0",
    "react-error-boundary": "^6.1.2",
